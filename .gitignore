#----Root .gitignore ----#

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage
*.lcov
.nyc_output

# Dependency directories
node_modules/
jspm_packages/
bower_components
web_modules/

# TypeScript cache
*.tsbuildinfo

# Package manager / tool caches
.npm
.eslintcache
.stylelintcache
.node_repl_history
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Build output
dist
out
.next
.nuxt
.svelte-kit/
.docusaurus
.serverless/
.fusebox/
.dynamodb/
build/Release

# Parcel / misc caches
.cache
.parcel-cache
.temp
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Expo / React Native
**/.expo/
**/.expo-shared/
**/web-build/
expo-env.d.ts

# Native local files
**/.kotlin/
**/ios/build/
**/ios/Pods/
**/android/.gradle/
**/android/app/build/

# Env files anywhere in the repo
**/.env
**/.env.*

# Editor / OS files anywhere in repo
**/.vscode/
**/.idea/
.vscode-test
.DS_Store
Thumbs.db

# Cloudflare / Wrangler
**/.dev.vars
**/.dev.vars.*
!**/.dev.vars.example
**/.wrangler/
cloudflared/
*yapme-dev.json
*.pem
*.key
*.crt

# Local databases / temp uploads
*.sqlite
*.sqlite3
*.db
uploads/
tmp/
temp/

# Native generated folders anywhere
**/ios/
**/android/

# dependency/build outputs anywhere
**/node_modules/
**/dist/
**/coverage/
